<Window x:Class="FlaUInspect.Views.ProcessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:FlaUInspect.Core.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:FlaUInspect.Models"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        xmlns:viewModels="clr-namespace:FlaUInspect.ViewModels"
        Title="{Binding WindowTitle}"
        Width="800"
        Height="450"
        d:DataContext="{d:DesignInstance viewModels:ProcessViewModel}"
        Background="{DynamicResource PrimaryWindowBackgroundBrush}"
        Closed="ProcessWindowOnClosed"
        Topmost="{Binding IsAlwaysOnTop}"
        mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Controls/ImageStyles.xaml" />
                <ResourceDictionary Source="../Resources/Icons.xaml" />
                <ResourceDictionary Source="/Resources/DetailsIcons.xaml" />
                <ResourceDictionary Source="/Resources/RibbonIcons.xaml" />
                <ResourceDictionary Source="/Controls/PatternExpanderStyle.xaml" />
                <ResourceDictionary Source="/Controls/GroupStyle.xaml" />
                <ResourceDictionary Source="/Controls/ElementToggleExpander.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <system:Double x:Key="ButtonWidth">32</system:Double>
            <system:Double x:Key="ButtonHeight">32</system:Double>

            <Style x:Key="SelectableLabel"
                   TargetType="{x:Type TextBox}">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="IsReadOnly" Value="True" />
            </Style>

            <SolidColorBrush x:Key="Details.Item.Background"
                             Color="{DynamicResource PrimaryColor}" />
            <SolidColorBrush x:Key="Details.Item.Background.Alternative"
                             Color="{DynamicResource SecondaryColor}" />

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:AlternationToColorConverter x:Key="AlternationToColorConverter"
                                                    AlternativeBrush="{StaticResource Details.Item.Background}"
                                                    Brush="{StaticResource Details.Item.Background.Alternative}" />

            <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"
                                                   ZeroCountVisibility="Hidden" />
            <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <converters:IndentConverter x:Key="IndentConverter" />

            <Style x:Key="RibbonButtonStyle"
                   BasedOn="{StaticResource {x:Type Button}}"
                   TargetType="{x:Type Button}">
                <Setter Property="Width" Value="{StaticResource ButtonWidth}" />
                <Setter Property="Height" Value="{StaticResource ButtonHeight}" />
                <Setter Property="Margin" Value="4" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style x:Key="RibbonToggleButtonStyle"
                   BasedOn="{StaticResource {x:Type ToggleButton}}"
                   TargetType="{x:Type ToggleButton}">
                <Setter Property="Width" Value="{StaticResource ButtonWidth}" />
                <Setter Property="Height" Value="{StaticResource ButtonHeight}" />
                <Setter Property="Margin" Value="4" />
            </Style>

            <Style x:Key="ProcessRadioButtonStyle"
                   BasedOn="{StaticResource RibbonRadioButtonStyle}"
                   TargetType="RadioButton">
                <Setter Property="Width" Value="{StaticResource ButtonWidth}" />
                <Setter Property="Height" Value="{StaticResource ButtonHeight}" />
            </Style>

            <Style x:Key="ViewBoxStyle"
                   TargetType="Viewbox">
                <Setter Property="Width" Value="20" />
                <Setter Property="Height" Value="20" />
                <Setter Property="Stretch" Value="Uniform" />
            </Style>
            <system:Double x:Key="ButtonWidth1">32</system:Double>
            <system:Double x:Key="ButtonHeight1">32</system:Double>

            <DataTemplate x:Key="RecordedStepTemplate" DataType="{x:Type viewModels:RecordedStep}">
                <Border BorderBrush="{DynamicResource TextBrush}"
                        BorderThickness="1"
                        CornerRadius="2"
                        Margin="4,4,4,2"
                        Padding="6">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center">
                                <Run Text="Step " /><Run Text="{Binding StepNumber, Mode=OneWay}" />
                                <Run Text="  |  " /><Run Text="{Binding ControlTypeStr, Mode=OneTime}" />
                                <Run Text="  |  &quot;" /><Run Text="{Binding ElementName, Mode=OneTime}" /><Run Text="&quot;" />
                            </TextBlock>
                            <Button Grid.Column="1"
                                    Content="Copy All"
                                    Padding="6,2"
                                    Margin="4,0,2,0"
                                    ToolTip="Copy all locators for this step"
                                    Command="{Binding CopyAllCommand}" />
                            <Button Grid.Column="2"
                                    Content="×"
                                    Padding="6,2"
                                    FontWeight="Bold"
                                    ToolTip="Remove this step"
                                    Command="{Binding DeleteCommand}" />
                        </Grid>

                        <Grid Margin="0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontWeight="SemiBold"
                                       Text="Window  :" />
                            <TextBox Grid.Column="1"
                                     IsReadOnly="True"
                                     Text="{Binding WindowLocator, Mode=OneTime}"
                                     Style="{StaticResource SelectableLabel}"
                                     TextWrapping="Wrap" />
                        </Grid>

                        <Grid Margin="0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontWeight="SemiBold"
                                       Text="Dialog  :" />
                            <TextBox Grid.Column="1"
                                     IsReadOnly="True"
                                     Text="{Binding DialogLocator, Mode=OneTime}"
                                     Style="{StaticResource SelectableLabel}"
                                     TextWrapping="Wrap" />
                        </Grid>

                        <Separator Margin="0,5" />

                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontWeight="SemiBold"
                                       Text="[1] AutomationId :" />
                            <TextBox Grid.Column="1"
                                     IsReadOnly="True"
                                     Text="{Binding AutomationIdLocator, Mode=OneTime}"
                                     Style="{StaticResource SelectableLabel}"
                                     TextWrapping="Wrap" />
                            <Button Grid.Column="2"
                                    Content="Copy"
                                    Padding="6,2"
                                    Margin="4,0,0,0"
                                    Command="{Binding CopyAutomationIdCommand}" />
                        </Grid>

                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontWeight="SemiBold"
                                       Text="[2] Name         :" />
                            <TextBox Grid.Column="1"
                                     IsReadOnly="True"
                                     Text="{Binding NameLocator, Mode=OneTime}"
                                     Style="{StaticResource SelectableLabel}"
                                     TextWrapping="Wrap" />
                            <Button Grid.Column="2"
                                    Content="Copy"
                                    Padding="6,2"
                                    Margin="4,0,0,0"
                                    Command="{Binding CopyNameCommand}" />
                        </Grid>

                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontWeight="SemiBold"
                                       Text="[3] XPath        :" />
                            <TextBox Grid.Column="1"
                                     IsReadOnly="True"
                                     Text="{Binding XPathLocator, Mode=OneTime}"
                                     Style="{StaticResource SelectableLabel}"
                                     TextWrapping="Wrap" />
                            <Button Grid.Column="2"
                                    Content="Copy"
                                    Padding="6,2"
                                    Margin="4,0,0,0"
                                    Command="{Binding CopyXPathCommand}" />
                        </Grid>

                    </StackPanel>
                </Border>
            </DataTemplate>

        </ResourceDictionary>

    </Window.Resources>
    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal">
            <Button Margin="8"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Click="SelectWindowClick"
                    Style="{StaticResource RibbonButtonStyle}">
                <Viewbox Style="{StaticResource ViewBoxStyle}">
                    <ContentControl Content="{StaticResource OpenIcon}" />
                </Viewbox>
            </Button>

            <Border Width="8"
                    Background="Transparent"
                    BorderBrush="Transparent" />

            <Button Command="{Binding RefreshCommand}"
                    Style="{StaticResource RibbonButtonStyle}"
                    ToolTip="Refresh. Reload the UI Automation tree">
                <Viewbox Style="{StaticResource ViewBoxStyle}">
                    <ContentControl Content="{StaticResource RefreshIcon}" />
                </Viewbox>
            </Button>

            <Border Width="8"
                    Background="Transparent"
                    BorderBrush="Transparent" />

            <RadioButton GroupName="SelectionMode"
                         IsChecked="{Binding EnableHoverMode}"
                         Style="{StaticResource ProcessRadioButtonStyle}">
                <ButtonBase.ToolTip>
                    <TextBlock>
                        Enable HoverMode (use Ctrl).<LineBreak />
                        To select control press and hold Ctrl button place mouse cursor over a coltrol.</TextBlock>
                </ButtonBase.ToolTip>
                <Viewbox Style="{StaticResource ViewBoxStyle}">
                    <ContentControl Content="{StaticResource HighLightSelectionModeIcon}" />
                </Viewbox>
            </RadioButton>

            <RadioButton GroupName="SelectionMode"
                         IsChecked="{Binding EnableHighLightSelectionMode}"
                         Style="{StaticResource ProcessRadioButtonStyle}">
                <ButtonBase.ToolTip>
                    <TextBlock>
                        Enable Select Mode.<LineBreak />
                        Highlight selected control.</TextBlock>
                </ButtonBase.ToolTip>
                <Viewbox Style="{StaticResource ViewBoxStyle}">
                    <ContentControl Content="{StaticResource EnableHoverModeIcon}" />
                </Viewbox>
            </RadioButton>
            <RadioButton GroupName="SelectionMode"
                         IsChecked="{Binding EnableFocusTrackingMode}"
                         Style="{StaticResource ProcessRadioButtonStyle}">
                <ButtonBase.ToolTip>
                    <TextBlock>
                        Focus Tracking.<LineBreak />
                        The focused control will be selected in tree.</TextBlock>
                </ButtonBase.ToolTip>
                <Viewbox Style="{StaticResource ViewBoxStyle}">
                    <ContentControl Content="{StaticResource EnableFocusTrackingModeIcon}" />
                </Viewbox>
            </RadioButton>

            <Border Width="8"
                    Background="Transparent"
                    BorderBrush="Transparent" />

            <Button Command="{Binding CaptureSelectedItemCommand}"
                    Style="{StaticResource RibbonButtonStyle}">
                <ButtonBase.ToolTip>
                    <TextBlock>
                        Capture selected item.<LineBreak />
                        Export to PNG file.</TextBlock>
                </ButtonBase.ToolTip>
                <Viewbox>
                    <ContentControl Content="{StaticResource CaptureSelectedItemIcon}" />
                </Viewbox>
            </Button>

            <Grid>
                <Button Command="{Binding CurrentElementSaveStateCommand}"
                        Style="{StaticResource RibbonButtonStyle}">
                    <ButtonBase.ToolTip>
                        <TextBlock>
                            Get current element state.<LineBreak />
                            Copy state of current element to clipboard.</TextBlock>
                    </ButtonBase.ToolTip>
                    <Viewbox>
                        <ContentControl Content="{StaticResource GetStateIcon}" />
                    </Viewbox>
                </Button>
                <Grid x:Name="CopiedNotificationCurrentElementSaveStateGrid"
                      Background="DarkBlue"
                      Visibility="Collapsed">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               Text="Copied." />
                </Grid>
            </Grid>

            <Grid>
                <Button Command="{Binding CopyDetailsToClipboardCommand}"
                        Style="{StaticResource RibbonButtonStyle}"
                        ToolTip="Copy current element state to clipboard">
                    <StackPanel Orientation="Vertical">
                        <Viewbox Width="20"
                                 Height="20"
                                 Stretch="Uniform">
                            <ContentControl Content="{StaticResource PropertiesIcon}" />
                        </Viewbox>
                    </StackPanel>
                </Button>
                <Grid x:Name="CopiedNotificationGrid"
                      Background="DarkBlue"
                      Visibility="Collapsed">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               Text="Copied." />
                </Grid>
            </Grid>

            <ToggleButton IsChecked="{Binding EnableXPath}"
                          Style="{StaticResource RibbonToggleButtonStyle}">
                <ButtonBase.ToolTip>
                    <TextBlock>
                        Display XPath to the current element.
                    </TextBlock>
                </ButtonBase.ToolTip>
                <Viewbox Style="{StaticResource ViewBoxStyle}">
                    <ContentControl Content="{StaticResource EnableXPathIcon}" />
                </Viewbox>
            </ToggleButton>

            <Border Width="8"
                    Background="Transparent"
                    BorderBrush="Transparent" />

            <ToggleButton IsChecked="{Binding IsRecording}"
                          Style="{StaticResource RibbonToggleButtonStyle}">
                <ButtonBase.ToolTip>
                    <TextBlock>
                        Record Mode.<LineBreak />
                        Ctrl+Click an element in the tree to record it as a step.</TextBlock>
                </ButtonBase.ToolTip>
                <TextBlock Text="REC"
                           FontSize="9"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </ToggleButton>

            <Button Command="{Binding ClearRecordingCommand}"
                    Style="{StaticResource RibbonButtonStyle}"
                    ToolTip="Clear all recorded steps">
                <TextBlock Text="CLR"
                           FontSize="9"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>

            <ToggleButton IsChecked="{Binding IsAutoRecording}"
                          Style="{StaticResource RibbonToggleButtonStyle}">
                <ButtonBase.ToolTip>
                    <TextBlock>
                        Auto Record Mode.<LineBreak />
                        Automatically records every element that receives focus in the target app.</TextBlock>
                </ButtonBase.ToolTip>
                <TextBlock Text="AUTO"
                           FontSize="8"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </ToggleButton>

            <ToggleButton IsChecked="{Binding IsDialogCapturing}"
                          Style="{StaticResource RibbonToggleButtonStyle}">
                <ButtonBase.ToolTip>
                    <TextBlock>
                        Dialog Capture Mode.<LineBreak />
                        Ctrl+Click a window/dialog root in the tree to record every descendant element into the Dialog tab.</TextBlock>
                </ButtonBase.ToolTip>
                <TextBlock Text="DLG"
                           FontSize="9"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </ToggleButton>

            <ToggleButton IsChecked="{Binding IsAlwaysOnTop}"
                          Style="{StaticResource RibbonToggleButtonStyle}">
                <ButtonBase.ToolTip>
                    <TextBlock>
                        Always on Top.<LineBreak />
                        Keep this inspector window above all other windows.</TextBlock>
                </ButtonBase.ToolTip>
                <TextBlock Text="TOP"
                           FontSize="9"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </ToggleButton>
        </StackPanel>
        <Grid>
            <Grid.Resources />
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0"
                      Grid.RowSpan="2"
                      Grid.Column="0"
                      Header="Elements"
                      Style="{StaticResource GroupBoxStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="2,2,2,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      x:Name="SearchScopeCombo"
                                      MinWidth="100"
                                      Margin="0,0,4,0"
                                      VerticalContentAlignment="Center"
                                      ToolTip="Choose which field to filter by"
                                      ItemsSource="{Binding SearchScopes}"
                                      SelectedItem="{Binding SearchScope}" />
                            <TextBox Grid.Column="1"
                                     x:Name="SearchTextBox"
                                     Padding="4,2"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Type and press Enter or click Search (case-insensitive). Matches are highlighted; tree is not filtered."
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding ApplySearchCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="2"
                                    Content="Search"
                                    Padding="8,2"
                                    Margin="2,0,0,0"
                                    FontWeight="SemiBold"
                                    ToolTip="Search (Enter)"
                                    Command="{Binding ApplySearchCommand}" />
                        </Grid>
                        <ProgressBar Grid.Row="1"
                                     Height="2"
                                     Margin="0,2,0,0"
                                     IsIndeterminate="True"
                                     Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>

                    <ListView Grid.Row="1"
                              x:Name="TreeViewControl"
                              ItemsSource="{Binding Elements}"
                              ScrollViewer.CanContentScroll="True"
                              SelectedItem="{Binding SelectedItem}"
                              SelectionChanged="TreeOnSelectionChanged"
                              PreviewMouseLeftButtonDown="TreeViewControl_PreviewMouseLeftButtonDown">

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="{Binding Level, Converter={StaticResource IndentConverter}, Mode=OneWay}"
                                            Orientation="Horizontal">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Copy Element Tree"
                                                      Click="CopyElementTree_Click" />
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>

                                    <ToggleButton Width="16"
                                                  Height="16"
                                                  Click="ToggleButton_Click"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsExpanded}"
                                                  Style="{StaticResource ElementToggleExpanderStyle}"
                                                  Visibility="{Binding Children.Count, Converter={StaticResource CountToVisibilityConverter}}" />


                                    <TextBlock Margin="4,0,0,0"
                                               ToolTip="{Binding}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMatch}" Value="True">
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                        <Setter Property="Foreground" Value="#FFE08A1F" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} &quot;{1}&quot; &quot;{2}&quot;">
                                                <Binding Path="ControlType" />
                                                <Binding Path="Name" />
                                                <Binding Path="AutomationId" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock Grid.Row="1"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="Loading ..."
                               Visibility="{Binding Elements.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=EqualsZero}" />
                </Grid>
            </GroupBox>
            <GridSplitter Grid.Row="0"
                          Grid.RowSpan="2"
                          Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource PrimaryWindowBackgroundBrush}" />


            <TabControl Grid.Row="0"
                        Grid.Column="2"
                        Background="{DynamicResource PrimaryWindowBackgroundBrush}">

                <!-- ═══ Details tab (existing content) ═══ -->
                <TabItem Header="Details">
                    <DockPanel LastChildFill="True">
                        <Grid>
                            <DockPanel LastChildFill="True"
                                       Visibility="{Binding TreeViewControl.SelectedItem, Converter={StaticResource NullToVisibilityConverter}}">
                                <ScrollViewer>
                                    <ItemsControl ItemsSource="{Binding ElementPatterns}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid d:DataContext="{d:DesignInstance {x:Type models:ElementPatternItem}}"
                                                      Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Expander IsExpanded="{Binding IsExpanded}"
                                                              Style="{StaticResource PatternExpanderStyle}">
                                                        <Expander.Header>
                                                            <DockPanel LastChildFill="True">
                                                                <Viewbox Width="16"
                                                                         Height="16"
                                                                         Margin="0,0,1,0"
                                                                         Stretch="Uniform">
                                                                    <ContentControl Style="{StaticResource DetailsResourceStyle}" />
                                                                </Viewbox>
                                                                <TextBlock VerticalAlignment="Center"
                                                                           FontWeight="Bold"
                                                                           Text="{Binding PatternName}" />
                                                            </DockPanel>
                                                        </Expander.Header>
                                                        <ItemsControl AlternationCount="2"
                                                                      Foreground="{DynamicResource TextBrush}"
                                                                      Grid.IsSharedSizeScope="True"
                                                                      ItemsSource="{Binding Children}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Margin="0"
                                                                            Padding="0">
                                                                        <Border.Background>
                                                                            <MultiBinding Converter="{StaticResource AlternationToColorConverter}">
                                                                                <Binding Path="(ItemsControl.AlternationIndex)"
                                                                                         RelativeSource="{RelativeSource Mode=FindAncestor,
                                                                                                                         AncestorType=ContentPresenter}" />
                                                                            </MultiBinding>
                                                                        </Border.Background>

                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="130"
                                                                                                  SharedSizeGroup="DetailColumnKey" />
                                                                                <ColumnDefinition Width="*" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBox Grid.Column="0"
                                                                                     IsReadOnly="True"
                                                                                     Text="{Binding Key}">
                                                                                <TextBox.Style>
                                                                                    <Style BasedOn="{StaticResource SelectableLabel}"
                                                                                           TargetType="{x:Type TextBox}">
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Value}"
                                                                                                         Value="Yes">
                                                                                                <Setter Property="FontWeight" Value="Bold" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBox.Style>
                                                                            </TextBox>
                                                                            <TextBox Grid.Column="1"
                                                                                     Margin="5,0,0,0"
                                                                                     IsReadOnly="True"
                                                                                     Text="{Binding Value}"
                                                                                     TextWrapping="Wrap">
                                                                                <TextBox.Style>
                                                                                    <Style BasedOn="{StaticResource SelectableLabel}"
                                                                                           TargetType="{x:Type TextBox}">
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Value}"
                                                                                                         Value="Yes">
                                                                                                <Setter Property="TextBox.Foreground" Value="Green" />
                                                                                                <Setter Property="FontWeight" Value="Bold" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBox.Style>
                                                                            </TextBox>
                                                                            <Button Grid.Column="1"
                                                                                    Click="InvokePatternActionHandler"
                                                                                    Content="{Binding Value}">
                                                                                <Button.Style>
                                                                                    <Style TargetType="{x:Type Button}">
                                                                                        <Setter Property="Visibility" Value="Hidden" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding HasExecutableAction}"
                                                                                                         Value="True">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Button.Style>
                                                                            </Button>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Expander>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="Select item in tree ..."
                                       Visibility="{Binding Elements.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=EqualsZero}" />
                        </Grid>
                    </DockPanel>
                </TabItem>

                <!-- ═══ Locator tab (recorded steps) ═══ -->
                <TabItem Header="Locator">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top"
                                    Orientation="Horizontal"
                                    Margin="4,4,4,2">
                            <Button Content="Copy All Steps"
                                    Padding="8,4"
                                    Margin="0,0,4,0"
                                    ToolTip="Copy all recorded steps to clipboard"
                                    Command="{Binding CopyAllStepsCommand}" />
                            <Button Content="Clear All Steps"
                                    Padding="8,4"
                                    ToolTip="Remove all recorded steps"
                                    Command="{Binding ClearRecordingCommand}" />
                        </StackPanel>
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding RecordedSteps}"
                                          ItemTemplate="{StaticResource RecordedStepTemplate}" />
                        </ScrollViewer>

                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Text="No steps recorded.&#x0a;Enable Record Mode (REC) and Ctrl+Click elements in the tree."
                                   Visibility="{Binding RecordedSteps.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=EqualsZero}" />
                    </Grid>
                    </DockPanel>
                </TabItem>

                <!-- ═══ Dialog tab (captured dialog subtree) ═══ -->
                <TabItem Header="Dialog">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top"
                                    Orientation="Horizontal"
                                    Margin="4,4,4,2">
                            <Button Content="Copy All Steps"
                                    Padding="8,4"
                                    Margin="0,0,4,0"
                                    ToolTip="Copy all captured dialog steps to clipboard"
                                    Command="{Binding CopyAllDialogStepsCommand}" />
                            <Button Content="Clear All Steps"
                                    Padding="8,4"
                                    ToolTip="Remove all captured dialog steps"
                                    Command="{Binding ClearDialogCaptureCommand}" />
                            <ProgressBar Width="80"
                                         Height="6"
                                         Margin="8,0,0,0"
                                         VerticalAlignment="Center"
                                         IsIndeterminate="True"
                                         Visibility="{Binding IsCapturingDialog, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding DialogCapturedSteps}"
                                              ItemTemplate="{StaticResource RecordedStepTemplate}" />
                            </ScrollViewer>

                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       Text="No dialog captured.&#x0a;Enable Dialog Capture (DLG) and Ctrl+Click a window/dialog root in the tree."
                                       Visibility="{Binding DialogCapturedSteps.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter=EqualsZero}" />
                        </Grid>
                    </DockPanel>
                </TabItem>

            </TabControl>

            <GroupBox Grid.Row="1"
                      Grid.Column="2"
                      Margin="0,4"
                      Header="XPath"
                      Style="{StaticResource GroupBoxStyle}"
                      Visibility="{Binding EnableXPath, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding SelectedItem.XPath, ElementName=TreeViewControl}" />
            </GroupBox>
        </Grid>

    </DockPanel>
</Window>